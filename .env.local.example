# ============================================
# DAXUS PLATFORM BR - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# OpenAI
OPENAI_API_KEY=sk-...

# Notion
NOTION_TOKEN=secret_...
NOTION_COURSES_DB_ID=079c32bcda2c82a39d0581edbc8b104f
NOTION_CHATS_DB_ID=your_output_chats_database_id_here
NOTION_PROFILES_DB_ID=your_legacy_output_profiles_database_id_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase - email validation allowlist
# Leave blank to reuse the main Supabase project.
NEXT_PUBLIC_AUTH_SUPABASE_URL=https://your-validation-project.supabase.co
AUTH_SUPABASE_SERVICE_ROLE_KEY=your_validation_service_role_key_here
AUTH_SUPABASE_USERS_TABLE=users_br
PDI_OUTPUT_TABLE=PDI_BR

# Email verification
# Uses Supabase Auth email OTP. Configure Auth email settings in Supabase.
